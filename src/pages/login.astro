---
import '../styles/global.css'; // Pastikan tailwind terhubung

// Ambil error dari URL jika login gagal
const error = Astro.url.searchParams.get('error');
---

<html lang="id">
  <head>
    <title>Login - CMS</title>
  </head>
  <body class="bg-gray-100 flex items-center justify-center h-screen">

    <div class="bg-white p-8 rounded-xl shadow-lg max-w-sm w-full">
      <h1 class="text-2xl font-bold text-center mb-6 text-gray-800">Login ke Dashboard</h1>

      {error && (
        <div class="bg-red-100 text-red-700 p-3 rounded mb-4 text-sm text-center">
          {error}
        </div>
      )}

      <form action="/api/auth/signin" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">Email</label>
          <input type="email" name="email" required class="mt-1 block w-full border border-gray-300 rounded-md p-2 focus:ring-blue-500 focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Password</label>
          <input type="password" name="password" required class="mt-1 block w-full border border-gray-300 rounded-md p-2 focus:ring-blue-500 focus:border-blue-500" />
        </div>
        <button type="submit" class="w-full bg-blue-600 text-white font-semibold py-2 rounded-md hover:bg-blue-700 transition">
          Masuk
        </button>
      </form>

      <a href="/" class="block text-center mt-4 text-sm text-gray-500 hover:underline">Kembali ke Beranda</a>
    </div>

  </body>
</html>