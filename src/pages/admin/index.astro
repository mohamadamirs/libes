---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies);

const success = Astro.url.searchParams.get('success');
const errorMessage = Astro.url.searchParams.get('error');

// Ambil data artikel beserta nama penulisnya
const { data: articles, error } = await supabase
  .from('articles')
  .select('*, profiles(full_name)')
  .order('created_at', { ascending: false });

// Log data untuk melihat isi lengkapnya di terminal
console.log("=== DEBUG DATA ARTIKEL ADMIN ===");
console.log(JSON.stringify(articles, null, 2));
console.log("===============================");

if (error) {
  console.error("ERROR QUERY ADMIN:", error.message);
}

// Fungsi helper untuk format tanggal
const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};
---

<DashboardLayout title="Admin Dashboard">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
      <div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight">
          Manajemen Artikel
        </h1>
        <p class="text-slate-500 mt-2">Tinjau, setujui, atau tolak karya tulis yang masuk dari komunitas.</p>
      </div>
      
      <div class="flex items-center gap-2 bg-blue-50 px-4 py-2 rounded-lg border border-blue-100">
        <span class="text-blue-600 font-bold">{articles?.length || 0}</span>
        <span class="text-blue-800 text-sm font-medium">Total Artikel</span>
      </div>
    </div>

    <!-- Notifikasi -->
    {success && (
      <div class="mb-8 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-5 py-4 rounded-xl shadow-sm animate-in fade-in slide-in-from-top-4 duration-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm font-semibold">{success}</p>
      </div>
    )}

    {errorMessage && (
      <div class="mb-8 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-5 py-4 rounded-xl shadow-sm animate-in fade-in slide-in-from-top-4 duration-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-rose-500" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm font-semibold">{errorMessage}</p>
      </div>
    )}

    <div class="grid gap-6">
      {articles?.map(article => (
        <div class="group bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-md transition-all duration-300">
          <div class="p-6 md:p-8">
            <div class="flex flex-col lg:flex-row justify-between items-start gap-6">
              
              <!-- Konten Artikel -->
              <div class="grow space-y-4">
                <div class="flex flex-wrap items-center gap-3">
                  {article.status === 'published' && (
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700 uppercase tracking-wider">
                      Published
                    </span>
                  )}
                  {article.status === 'rejected' && (
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-rose-100 text-rose-700 uppercase tracking-wider">
                      Rejected
                    </span>
                  )}
                  {article.status === 'pending' && (
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-700 animate-pulse uppercase tracking-wider border border-amber-200">
                      Pending Review
                    </span>
                  )}
                  <span class="text-slate-400 text-sm">•</span>
                  <time class="text-slate-500 text-sm font-medium flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {formatDate(article.created_at)}
                  </time>
                </div>

                <div>
                  <h2 class="text-2xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors duration-300 mb-2">
                    {article.title}
                  </h2>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 text-xs font-bold border border-slate-200">
                      {article.profiles?.full_name?.charAt(0) || 'U'}
                    </div>
                    <p class="text-slate-700 font-semibold text-sm">
                      Oleh: <span class="text-slate-900 underline decoration-blue-200 underline-offset-4">{article.profiles?.full_name || 'Penulis Anonim'}</span>
                    </p>
                  </div>
                </div>

                <div class="bg-slate-50 p-5 rounded-xl border border-slate-100 italic text-slate-600 text-sm line-clamp-3 leading-relaxed">
                  "{article.content}"
                </div>
              </div>

              <!-- Aksi Admin -->
              <div class="w-full lg:w-auto shrink-0 flex lg:flex-col gap-3">
                {article.status === 'pending' ? (
                  <div class="flex lg:flex-col gap-3 w-full">
                    <!-- Form untuk Publish (Tetap Langsung) -->
                    <form action="/api/articles/update-status" method="POST" class="w-full">
                      <input type="hidden" name="article_id" value={article.id} />
                      <button
                        type="submit"
                        name="status"
                        value="published"
                        class="flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-200 transition-all duration-300 w-full"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        Publish
                      </button>
                    </form>

                    <!-- Tombol Tolak (Membuka Modal) -->
                    <button
                      type="button"
                      data-article-id={article.id}
                      data-article-title={article.title}
                      class="btn-open-rejection flex items-center justify-center gap-2 px-6 py-3 bg-white text-rose-600 border-2 border-rose-100 rounded-xl font-bold hover:bg-rose-50 hover:border-rose-200 transition-all duration-300 w-full"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                      </svg>
                      Tolak
                    </button>
                  </div>
                ) : (
                  <div class="flex flex-col items-center justify-center p-4 bg-slate-50 border border-slate-200 rounded-xl min-w-[140px]">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Status Selesai</p>
                    <span class={`text-sm font-bold ${article.status === 'published' ? 'text-emerald-600' : 'text-rose-600'}`}>
                       {article.status === 'published' ? '✅ Terbit' : '❌ Ditolak'}
                    </span>
                    {article.status === 'rejected' && article.rejection_reason && (
                      <p class="text-[10px] text-rose-400 mt-2 text-center italic max-w-[120px] line-clamp-2" title={article.rejection_reason}>
                        Ket: {article.rejection_reason}
                      </p>
                    )}
                  </div>
                )}
              </div>

            </div>
          </div>
        </div>
      ))}

      {articles?.length === 0 && (
        <div class="text-center py-20 bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200">
          <div class="text-5xl mb-4">📭</div>
          <h3 class="text-xl font-bold text-slate-900">Belum ada artikel</h3>
          <p class="text-slate-500">Karya tulis dari penulis akan muncul di sini untuk ditinjau.</p>
        </div>
      )}
    </div>
  </div>

  <!-- MODAL PENOLAKAN -->
  <dialog id="modal-rejection" class="m-auto p-0 bg-transparent outline-none border-none backdrop:bg-slate-900/60 backdrop:backdrop-blur-sm w-[90%] max-w-md animate-in fade-in zoom-in duration-300">
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
      <div class="bg-rose-600 p-6 text-white">
        <h3 class="text-xl font-bold">Tolak Artikel?</h3>
        <p class="text-rose-100 text-sm mt-1" id="rejection-target-title">Judul Artikel</p>
      </div>
      
      <form action="/api/articles/update-status" method="POST" class="p-8">
        <input type="hidden" name="article_id" id="rejection-article-id" />
        <input type="hidden" name="status" value="rejected" />
        
        <label class="block text-sm font-bold text-slate-700 mb-2">Alasan Penolakan</label>
        <textarea 
          name="rejection_reason" 
          required 
          placeholder="Tuliskan alasan kenapa artikel ini ditolak (misal: SARA, konten tidak sesuai, dll)..." 
          class="w-full h-32 p-4 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:ring-2 focus:ring-rose-500 focus:border-transparent outline-none transition-all resize-none mb-6"
        ></textarea>

        <div class="flex gap-3">
          <button 
            type="button" 
            id="btn-close-rejection"
            class="flex-1 py-3 bg-slate-100 text-slate-700 font-bold rounded-xl hover:bg-slate-200 transition-colors"
          >
            Batal
          </button>
          <button 
            type="submit" 
            class="flex-1 py-3 bg-rose-600 text-white font-bold rounded-xl hover:bg-rose-700 transition-colors shadow-lg shadow-rose-200"
          >
            Ya, Tolak
          </button>
        </div>
      </form>
    </div>
  </dialog>
</DashboardLayout>

<script>
  // Script Client-side untuk menangani Modal
  document.addEventListener('astro:page-load', () => {
    const modal = document.getElementById('modal-rejection') as HTMLDialogElement;
    const btnClose = document.getElementById('btn-close-rejection');
    const inputId = document.getElementById('rejection-article-id') as HTMLInputElement;
    const labelTitle = document.getElementById('rejection-target-title');
    const openButtons = document.querySelectorAll('.btn-open-rejection');

    openButtons.forEach(button => {
      button.addEventListener('click', () => {
        const id = (button as HTMLElement).getAttribute('data-article-id');
        const title = (button as HTMLElement).getAttribute('data-article-title');
        
        if (id && modal) {
          inputId.value = id;
          if (labelTitle) labelTitle.textContent = title || "Artikel Tanpa Judul";
          modal.showModal();
        }
      });
    });

    btnClose?.addEventListener('click', () => {
      modal?.close();
    });

    // Tutup modal jika klik di luar area konten (backdrop)
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.close();
      }
    });
  });
</script>