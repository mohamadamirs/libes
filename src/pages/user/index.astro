---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import { supabase } from '../../lib/supabase';
import { ArticleService } from '../../services/articleService';
import { formatFullDate } from '../../utils/date';
import { DashboardAction } from '../../components/features/ruang-suara/DashboardAction';

const user = Astro.locals.user;
const userName = Astro.locals.user_name || "User";
const userId = user?.id;

if (!user || !userId) {
  return Astro.redirect('/login');
}

const articleService = new ArticleService(supabase);
const { data: articles, error } = await articleService.getUserArticles(userId);

const success = Astro.url.searchParams.get('success');

// Statistik Sederhana
const stats = {
  total: articles?.length || 0,
  published: articles?.filter(a => a.status === 'published').length || 0,
  pending: articles?.filter(a => a.status === 'pending').length || 0,
};
---

<DashboardLayout title="Pusat Kontribusi - Ruang Suara">
  <div class="max-w-4xl mx-auto px-4 text-left">
    
    <!-- Header & Welcome -->
    <div class="mb-10">
      <h1 class="text-3xl font-black text-slate-900 tracking-tight text-left">
        Halo, <span class="text-blue-600">{userName?.split(' ')[0]}!</span>
      </h1>
      <p class="text-slate-500 mt-1 font-medium italic text-left">Lagi mikirin apa hari ini? Suarakan aja di sini.</p>
    </div>

    {success && (
      <div class="mb-8 p-4 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-2xl flex items-center gap-3 text-sm font-bold animate-in fade-in slide-in-from-top-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        {success}
      </div>
    )}

    <!-- Quick Actions & Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
      <DashboardAction client:load userName={userName} userId={userId} />

      <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200 shadow-sm flex flex-col justify-center text-center">
        <p class="text-4xl font-black text-blue-600 mb-1">{stats.total}</p>
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Suara Kamu</p>
      </div>
    </div>

    <!-- Feed Kontribusi Pribadi -->
    <div class="space-y-6">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-black text-slate-400 uppercase tracking-[0.2em]">Cerita Kamu</h2>
        <div class="flex gap-2 text-left">
           <Badge variant="outline" class="text-[8px] py-0.5">{stats.published} Terbit</Badge>
           <Badge variant="warning" class="text-[8px] py-0.5 bg-amber-50 text-amber-600 border-none shadow-none">{stats.pending} Menunggu</Badge>
        </div>
      </div>

      {articles && articles.length > 0 ? (
        articles.map((article) => (
          <div class="group bg-white p-6 rounded-3xl border border-slate-200 shadow-sm hover:border-blue-200 transition-all text-left">
            <div class="flex flex-col md:flex-row justify-between items-start gap-4">
              <div class="space-y-3 grow text-left">
                <div class="flex items-center gap-3">
                  {article.status === 'published' && <Badge variant="success" class="text-[8px] px-2 py-0.5 border-none">Terbit</Badge>}
                  {article.status === 'pending' && <Badge variant="warning" class="text-[8px] px-2 py-0.5 border-none">Menunggu Review</Badge>}
                  {article.status === 'rejected' && <Badge variant="error" class="text-[8px] px-2 py-0.5 border-none text-white bg-rose-500">Ditolak</Badge>}
                  <time class="text-[10px] font-medium text-slate-400 uppercase tracking-tight">{formatFullDate(article.created_at)}</time>
                </div>
                
                <div class="text-left">
                  <h3 class="text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-tight mb-1">
                    {article.title}
                  </h3>
                  <p class="text-slate-500 text-xs line-clamp-2 leading-relaxed">
                    {article.excerpt || article.content.substring(0, 100) + '...'}
                  </p>
                </div>

                {article.status === 'rejected' && article.rejection_reason && (
                  <div class="bg-rose-50 p-3 rounded-xl border border-rose-100 mt-2 text-left">
                    <p class="text-[10px] text-rose-700 font-bold uppercase mb-1">Catatan Admin:</p>
                    <p class="text-xs text-rose-600 italic">"{article.rejection_reason}"</p>
                  </div>
                )}
              </div>

              <div class="flex md:flex-col gap-2 shrink-0 w-full md:w-auto">
                <a href={`/ruang-suara/${article.id}`} class="flex-1 md:flex-none text-center px-4 py-2 bg-slate-50 text-slate-600 rounded-xl text-[10px] font-bold hover:bg-slate-100 transition-colors">
                  Lihat
                </a>
                <button class="flex-1 md:flex-none px-4 py-2 bg-white text-rose-600 border border-rose-100 rounded-xl text-[10px] font-bold hover:bg-rose-50 transition-colors md:opacity-0 md:group-hover:opacity-100 transition-opacity cursor-pointer">
                  Hapus
                </button>
              </div>
            </div>
          </div>
        ))
      ) : (
        <div class="text-center py-20 bg-slate-50 rounded-[2.5rem] border-2 border-dashed border-slate-200">
          <div class="text-4xl mb-4 text-left">✍️</div>
          <p class="text-slate-500 text-sm font-medium text-left">Belum ada cerita yang kamu bagikan.</p>
        </div>
      )}
    </div>

  </div>
</DashboardLayout>
