---
import Badge from "../ui/Badge.astro";
---
<section id="galeri" class="py-16 px-4 bg-slate-950 text-white overflow-hidden relative text-left">
  <div class="container mx-auto max-w-7xl relative z-10">
    <div class="mb-12 space-y-3 text-left">
      <Badge variant="outline" class="border-white/20 text-white px-3 py-1 text-[9px]">Dokumentasi</Badge>
      <h2 class="text-3xl md:text-6xl font-black tracking-tight italic font-serif text-left">Merawat Momen</h2>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10 text-left">
      {[1,2,3,4].map((i) => (
        <div class="relative aspect-square bg-white/5 border border-white/10 rounded-2xl overflow-hidden group">
          <div class="w-full h-full bg-white/5 group-hover:scale-105 transition-transform duration-700"></div>
        </div>
      ))}
    </div>

    <a href="/dokumentasi" class="inline-flex items-center gap-3 bg-white text-slate-950 px-8 py-4 rounded-2xl font-bold text-xs uppercase tracking-widest hover:bg-blue-500 hover:text-white transition-all">Galeri Penuh →</a>
  </div>
</section>
