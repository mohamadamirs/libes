---
import Badge from "../ui/Badge.astro";
---
<section id="agenda" class="py-16 px-4 bg-slate-50/50 text-left">
  <div class="container mx-auto max-w-7xl">
    <div class="flex flex-col md:flex-row items-start justify-between mb-12 gap-4 text-left">
      <div class="space-y-3 text-left">
        <Badge variant="warning" class="px-3 py-1 text-[9px]">Kegiatan</Badge>
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight text-left">Agenda <span class="text-blue-600 italic font-serif font-light">Rutin</span></h2>
      </div>
      <div id="label-agenda" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] pt-1 text-left md:text-right">Memuat Tanggal...</div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch text-left">
      <div class="lg:col-span-5 aspect-video lg:aspect-auto bg-slate-200 rounded-3xl overflow-hidden border border-slate-300 shadow-lg">
        <div class="w-full h-full flex flex-col items-center justify-center text-slate-400 text-center p-6 bg-gradient-to-br from-slate-100 to-slate-200">
          <p class="font-bold text-[9px] uppercase tracking-[0.3em]">Poster Kegiatan</p>
        </div>
      </div>

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6 lg:p-6 text-left">
        <div class="space-y-3 text-left">
          <h3 class="text-2xl font-bold text-slate-900 leading-tight">Diskusi & Nongkrong Mingguan</h3>
          <p class="text-sm md:text-lg text-slate-600 leading-relaxed max-w-2xl">Kumpul bareng teman-teman kolektif buat bahas isu terkini, bedah buku ringan, atau sekadar ngopi. Terbuka untuk umum!</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl text-left">
          <div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-left">
            <p class="text-[8px] font-black text-blue-600 uppercase tracking-widest mb-1">Waktu</p>
            <p class="text-sm font-bold text-slate-900">Setiap Minggu</p>
            <p class="text-[10px] text-slate-500 font-medium">15:00 WIB - Selesai</p>
          </div>
          <div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-left">
            <p class="text-[8px] font-black text-blue-600 uppercase tracking-widest mb-1">Lokasi</p>
            <p class="text-sm font-bold text-slate-900">Kedai Kopi Sekitar</p>
            <p class="text-[10px] text-slate-500 font-medium">Brebes (Lokasi Update di WA)</p>
          </div>
        </div>

        <a href="https://wa.me/628993986415" target="_blank" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-blue-600 text-white font-bold rounded-2xl hover:bg-slate-900 transition-all shadow-lg shadow-blue-200 w-full sm:w-auto text-sm">RSVP via WhatsApp</a>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('astro:page-load', () => {
  const labelAgenda = document.getElementById('label-agenda');
  const today = new Date();
  const dayOfWeek = today.getDay();
  const nextSunday = new Date(today);
  nextSunday.setDate(today.getDate() + (7 - dayOfWeek));
  const formatter = new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
  if (labelAgenda) labelAgenda.textContent = `Agenda Minggu Ini: ${formatter.format(nextSunday)}`;
});
</script>
