---
import { formatDate } from "../../../utils/date";
import Badge from "../../ui/Badge.astro";

interface Props {
  article: any;
}

const { article } = Astro.props;
---

<article class="group bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-slate-300 transition-all duration-300 flex flex-col h-full shadow-sm hover:shadow-md text-left">
  
  <div class="p-4 md:p-5 flex flex-col grow">
    
    <!-- HEADER: Info Penulis -->
    <div class="flex items-center gap-3 mb-4">
      <div class="w-9 h-9 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 text-sm font-bold border border-slate-200 shrink-0">
        {article.profiles?.full_name?.charAt(0) || 'U'}
      </div>
      <div class="overflow-hidden">
        <div class="flex items-center gap-2">
          <p class="text-[11px] font-black text-slate-900 truncate tracking-tight">
            {article.profiles?.full_name || 'Anonim'}
          </p>
          <span class="text-blue-600 text-[10px] font-bold cursor-pointer hover:underline">Ikuti</span>
        </div>
        <div class="flex items-center gap-1.5 text-[9px] text-slate-400 font-medium">
          <time>{formatDate(article.created_at)}</time>
          <span class="opacity-50">•</span>
          <span class="flex items-center gap-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {article.reading_time || 3} min
          </span>
        </div>
      </div>
    </div>

    <!-- BODY: Judul & Cuplikan -->
    <div class="space-y-2 mb-4 text-left">
      <h2 class="text-base md:text-lg font-extrabold text-slate-900 leading-snug group-hover:text-blue-700 transition-colors">
        <a href={`/ruang-suara/${article.id}`} class="hover:underline decoration-blue-500/30 underline-offset-4">
          {article.title}
        </a>
      </h2>
      <p class="text-slate-600 text-sm leading-relaxed line-clamp-3">
        {article.excerpt || (article.content ? article.content.substring(0, 120) + '...' : '')}
      </p>
    </div>

    <!-- VISUAL -->
    {article.image_url && (
      <a href={`/ruang-suara/${article.id}`} class="block relative aspect-video w-full mb-4 rounded-xl overflow-hidden bg-slate-50 border border-slate-100">
        <img 
          src={article.image_url} 
          alt={article.title} 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </a>
    )}

    <!-- FOOTER: Interaksi -->
    <div class="flex items-center justify-between pt-3 border-t border-slate-50 mt-auto">
      <div class="flex items-center gap-1 bg-slate-50 rounded-full p-1 border border-slate-100">
        <button class="flex items-center gap-1.5 px-3 py-1 text-slate-600 hover:bg-blue-50 hover:text-blue-600 rounded-full transition-all group/upvote">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover/upvote:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
          </svg>
          <span class="text-[10px] font-black uppercase tracking-wider">Dukung</span>
        </button>
        <div class="w-px h-4 bg-slate-200"></div>
        <button class="px-2 py-1 text-slate-400 hover:text-rose-600 rounded-full transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>

      <div class="flex items-center gap-2">
        <a href={`/ruang-suara/${article.id}#comments`} class="p-2 text-slate-400 hover:bg-slate-50 hover:text-blue-600 rounded-full transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Kategori Badge -->
    <div class="mt-3 flex justify-start">
      <Badge category={article.category || 'Suara'} class="opacity-70 group-hover:opacity-100 transition-opacity" />
    </div>

  </div>
</article>
